# Repo root — Unity project: First Principles/
# See also: https://github.com/github/gitignore/blob/main/Unity.gitignore

# Unity generated (any path — matches First Principles/Library, etc.)
**/Library/
**/Temp/
**/obj/
**/Build/
**/Builds/
**/Logs/
**/UserSettings/
**/MemoryCaptures/
**/Recordings/

.vscode/
.AppleDouble
.LSOverride
**/.DS_Store
._*

# Local / optional asset drops
**/AssetsExternal/
**/AssetsExternal.meta
[Aa]ssetsExternal/
[Aa]ssetsExternal.meta

# Keep .meta files for tracked Assets (do not ignore these)
!**/Assets/**/*.meta

# Autogenerated JetBrains Rider plugin
**/Assets/Plugins/Editor/JetBrains*

# Uncomment if you use Asset Store tools and want them ignored
# **/Assets/AssetStoreTools*

# Visual Studio / Rider / VS Code
.vs/
.gradle/
.consulo/
ExportedObj/

# Autogenerated solution & project files (Unity regenerates these)
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D crash / sysinfo
sysinfo.txt

# Builds & packages
*.apk
*.aab
*.unitypackage

# Crashlytics
crashlytics-build.properties

# macOS
Icon
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
